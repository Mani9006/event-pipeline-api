# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Sink Directories
SINK_FILE_DIR=./data/events
DLQ_DIR=./data/dead-letter

# Backpressure Settings
BP_MAX_QUEUE=10000
BP_MAX_CONCURRENCY=50
BP_DRAIN_INTERVAL=100

# Dead Letter Queue
DLQ_MAX_RETRIES=3
DLQ_ALERT_THRESHOLD=10

# Replay Settings
REPLAY_BATCH_SIZE=100
REPLAY_MAX_DAYS=30

# Validation
VALIDATION_STRICT=false

# Webhook Targets (optional)
WEBHOOK_URL_1=
WEBHOOK_SECRET_1=
WEBHOOK_URL_2=
WEBHOOK_SECRET_2=